{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/okinawa_midterm_indicator_review_manifest.schema.json",
  "title": "Okinawa mid-term indicator review manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "prefecture_code",
    "municipality_key",
    "plan_title",
    "plan_period",
    "source_url",
    "source_document_title",
    "reviewed_indicator_count",
    "major_indicator_count",
    "outcome_indicator_count",
    "evidence_packet_count",
    "island_indicator_count",
    "sdgs_priority_indicator_count",
    "qualitative_target_count",
    "national_comparison_provided_count",
    "source_value_note_count",
    "policy_achievement_assessed_indicator_count",
    "status",
    "updated_at",
    "next_review_scope",
    "quality_note"
  ],
  "properties": {
    "id": {"const": "okinawa-midterm-indicator-review-manifest"},
    "prefecture_code": {"const": "47"},
    "municipality_key": {"const": "okinawa-prefecture"},
    "plan_title": {"type": "string", "minLength": 1},
    "plan_period": {"const": "令和7年度～令和9年度"},
    "source_url": {"type": "string", "format": "uri"},
    "source_document_title": {"type": "string", "minLength": 1},
    "reviewed_indicator_count": {"const": 375},
    "major_indicator_count": {"const": 36},
    "outcome_indicator_count": {"const": 339},
    "evidence_packet_count": {"const": 375},
    "island_indicator_count": {"const": 32},
    "sdgs_priority_indicator_count": {"const": 43},
    "qualitative_target_count": {"const": 9},
    "national_comparison_provided_count": {"const": 174},
    "source_value_note_count": {"const": 1},
    "policy_achievement_assessed_indicator_count": {"const": 0},
    "status": {"const": "complete"},
    "updated_at": {"type": "string", "format": "date"},
    "next_review_scope": {"type": "string", "minLength": 1},
    "quality_note": {"type": "string", "minLength": 1}
  }
}
