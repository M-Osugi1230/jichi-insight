{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/wave1_policy_review_queue.schema.json",
  "title": "Jichi Insight Wave 1 policy review queue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "updated_at",
    "active_prefecture_code",
    "completed_prefecture_codes",
    "items"
  ],
  "properties": {
    "id": {
      "const": "wave1-policy-review-queue"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "active_prefecture_code": {
      "$ref": "#/$defs/prefectureCode"
    },
    "completed_prefecture_codes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/prefectureCode"
      }
    },
    "items": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "prefecture_code",
          "municipality_key",
          "order",
          "status",
          "source_ids",
          "current_plan_title",
          "source_inventory_status",
          "next_gate",
          "next_action",
          "priority_basis"
        ],
        "properties": {
          "prefecture_code": {
            "$ref": "#/$defs/prefectureCode"
          },
          "municipality_key": {
            "type": "string",
            "enum": [
              "hokkaido-prefecture",
              "miyagi-prefecture",
              "tokyo-metropolis",
              "aichi-prefecture",
              "osaka-prefecture",
              "hiroshima-prefecture",
              "kagawa-prefecture",
              "fukuoka-prefecture",
              "okinawa-prefecture"
            ]
          },
          "order": {
            "type": "integer",
            "minimum": 0,
            "maximum": 8
          },
          "status": {
            "type": "string",
            "enum": ["reviewed_reference", "active_review", "queued"]
          },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^policy-source-[a-z0-9-]+$"
            }
          },
          "current_plan_title": {
            "type": "string",
            "minLength": 1
          },
          "source_inventory_status": {
            "type": "string",
            "enum": [
              "reviewed",
              "policy_hierarchy_reviewed",
              "plan_kpi_entry_indexed",
              "plan_followup_entry_indexed",
              "strategic_plan_indexed"
            ]
          },
          "next_gate": {
            "type": "string",
            "enum": [
              "source_inventory",
              "policy_hierarchy",
              "kpi_catalog",
              "actuals_linkage"
            ]
          },
          "next_action": {
            "type": "string",
            "minLength": 1
          },
          "priority_basis": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "prefectureCode": {
      "type": "string",
      "enum": ["01", "04", "13", "23", "27", "34", "37", "40", "47"]
    }
  }
}