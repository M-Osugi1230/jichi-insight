{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/phase9_review_summary.schema.json",
  "title": "Phase 9 reviewed prefecture summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "status", "prefecture_count", "reviewed_target_statement_count", "evidence_packet_count", "evidence_coverage_percent", "policy_achievement_assessed_count", "ranking_eligible_record_count", "records", "updated_at"],
  "properties": {
    "id": {"const": "phase9-reviewed-prefecture-summary"},
    "status": {"const": "reviewed_complete"},
    "prefecture_count": {"const": 38},
    "reviewed_target_statement_count": {"type": "integer", "minimum": 38},
    "evidence_packet_count": {"type": "integer", "minimum": 38},
    "evidence_coverage_percent": {"const": 100},
    "policy_achievement_assessed_count": {"const": 0},
    "ranking_eligible_record_count": {"const": 0},
    "records": {
      "type": "array",
      "minItems": 38,
      "maxItems": 38,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["prefecture_code", "name", "slug", "batch_id", "plan_title", "plan_period", "source_url", "reviewed_target_statement_count", "evidence_packet_count", "document_count", "extraction_error_count", "route", "review_status", "policy_achievement_assessment_status", "ranking_eligibility"],
        "properties": {
          "prefecture_code": {"type": "string", "pattern": "^[0-9]{2}$"},
          "name": {"type": "string", "minLength": 2},
          "slug": {"type": "string", "pattern": "^[a-z-]+$"},
          "batch_id": {"enum": ["tohoku", "kanto", "chubu", "kinki", "chugoku", "shikoku", "kyushu-okinawa"]},
          "plan_title": {"type": "string", "minLength": 1},
          "plan_period": {"type": "string", "minLength": 1},
          "source_url": {"type": "string", "format": "uri", "pattern": "^https://"},
          "reviewed_target_statement_count": {"type": "integer", "minimum": 1},
          "evidence_packet_count": {"type": "integer", "minimum": 1},
          "document_count": {"type": "integer", "minimum": 1},
          "extraction_error_count": {"type": "integer", "minimum": 0},
          "route": {"type": "string", "pattern": "^/municipalities/phase9/[a-z-]+$"},
          "review_status": {"const": "reviewed"},
          "policy_achievement_assessment_status": {"const": "not_assessed"},
          "ranking_eligibility": {"const": "excluded_until_comparability_verified"}
        }
      }
    },
    "updated_at": {"type": "string", "format": "date"}
  }
}
