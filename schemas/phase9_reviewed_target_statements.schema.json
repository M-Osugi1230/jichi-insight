{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/phase9_reviewed_target_statements.schema.json",
  "title": "Phase 9 reviewed target statements",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "prefecture_code",
    "municipality_key",
    "slug",
    "name",
    "batch_id",
    "plan_title",
    "plan_period",
    "source_registry_path",
    "source_id",
    "source_title",
    "source_url",
    "landing_audit",
    "documents",
    "reviewed_target_statement_count",
    "evidence_packet_count",
    "review_method",
    "review_status",
    "policy_achievement_assessment_status",
    "ranking_eligibility",
    "records",
    "updated_at"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^phase9-[0-9]{2}-reviewed-target-statements$"},
    "prefecture_code": {"type": "string", "pattern": "^[0-9]{2}$"},
    "municipality_key": {"type": "string", "pattern": "^[a-z-]+-prefecture$"},
    "slug": {"type": "string", "pattern": "^[a-z-]+$"},
    "name": {"type": "string", "minLength": 2},
    "batch_id": {"enum": ["tohoku", "kanto", "chubu", "kinki", "chugoku", "shikoku", "kyushu-okinawa"]},
    "plan_title": {"type": "string", "minLength": 1},
    "plan_period": {"type": "string", "minLength": 1},
    "source_registry_path": {"type": "string", "pattern": "^data/catalog/phase9_.*_source_registry\\.json$"},
    "source_id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
    "source_title": {"type": "string", "minLength": 1},
    "source_url": {"type": "string", "format": "uri", "pattern": "^https://"},
    "landing_audit": {"type": "object"},
    "documents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url", "title", "content_type", "sha256", "size_bytes", "structural_count", "extracted_row_count", "reviewed_row_count"],
        "properties": {
          "url": {"type": "string", "format": "uri", "pattern": "^https://"},
          "title": {"type": "string", "minLength": 1},
          "content_type": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 1},
          "structural_count": {"type": "integer", "minimum": 0},
          "extracted_row_count": {"type": "integer", "minimum": 0},
          "reviewed_row_count": {"type": "integer", "minimum": 0}
        }
      }
    },
    "reviewed_target_statement_count": {"type": "integer", "minimum": 1},
    "evidence_packet_count": {"type": "integer", "minimum": 1},
    "review_method": {"const": "deterministic_official_source_review_v1"},
    "review_status": {"const": "reviewed"},
    "policy_achievement_assessment_status": {"const": "not_assessed"},
    "ranking_eligibility": {"const": "excluded_until_comparability_verified"},
    "records": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1500,
      "items": {"$ref": "#/$defs/targetRecord"}
    },
    "updated_at": {"type": "string", "format": "date"}
  },
  "$defs": {
    "targetRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "evidence_id",
        "display_order",
        "indicator_name_original",
        "target_statement_original",
        "numeric_tokens_original",
        "period_tokens_original",
        "matched_keywords",
        "keyword_match_kind",
        "unit_original",
        "population_scope_original",
        "aggregation_scope",
        "target_operator",
        "source_document_url",
        "source_document_title",
        "source_document_sha256",
        "source_location",
        "plan_history_boundary",
        "comparability",
        "review_method",
        "review_status",
        "policy_achievement_assessment_status"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^phase9-[0-9]{2}-target-[0-9]{4}$"},
        "evidence_id": {"type": "string", "pattern": "^phase9-[0-9]{2}-target-[0-9]{4}-evidence$"},
        "display_order": {"type": "integer", "minimum": 1, "maximum": 1500},
        "indicator_name_original": {"type": "string", "minLength": 1},
        "target_statement_original": {"type": "string", "minLength": 6},
        "numeric_tokens_original": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "period_tokens_original": {"type": "array", "items": {"type": "string", "minLength": 1}},
        "matched_keywords": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "keyword_match_kind": {"enum": ["explicit", "table_header_context"]},
        "unit_original": {"type": ["string", "null"]},
        "population_scope_original": {"type": ["string", "null"]},
        "aggregation_scope": {"enum": ["cumulative", "average", "period_specific", "not_stated"]},
        "target_operator": {"enum": ["minimum", "maximum", "strict_maximum", "approximate", "maintain", "increase", "decrease", "exact_or_unspecified"]},
        "source_document_url": {"type": "string", "format": "uri", "pattern": "^https://"},
        "source_document_title": {"type": "string", "minLength": 1},
        "source_document_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_location": {
          "type": "object",
          "required": ["location_kind"],
          "properties": {
            "location_kind": {"enum": ["pdf_text_line", "pdf_table_row", "workbook_row", "docx_paragraph", "docx_table_row", "html_table_row", "html_text_line"]},
            "page": {"type": "integer", "minimum": 1},
            "sheet": {"type": "string", "minLength": 1},
            "table": {"type": "integer", "minimum": 1},
            "row": {"type": "integer", "minimum": 1}
          },
          "additionalProperties": false
        },
        "plan_history_boundary": {"type": "string", "minLength": 20},
        "comparability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "reasons"],
          "properties": {
            "status": {"const": "not_comparable"},
            "reasons": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
          }
        },
        "review_method": {"const": "deterministic_official_source_review_v1"},
        "review_status": {"const": "reviewed"},
        "policy_achievement_assessment_status": {"const": "not_assessed"}
      }
    }
  }
}
