{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/miyagi_kpi_catalog.schema.json",
  "title": "Miyagi KPI catalog batch",
  "type": "object",
  "required": [
    "id",
    "municipality_key",
    "prefecture_code",
    "source_id",
    "source_document_url",
    "source_table_title",
    "target_group_number_start",
    "target_group_number_end",
    "series_number_start",
    "series_number_end",
    "items",
    "reviewed_at",
    "review_status",
    "confidence"
  ],
  "properties": {
    "id": {"type": "string"},
    "municipality_key": {"const": "miyagi-prefecture"},
    "prefecture_code": {"const": "04"},
    "source_id": {"const": "policy-source-miyagi-midterm-implementation-plan-2026"},
    "source_document_url": {"type": "string", "format": "uri"},
    "source_table_title": {"const": "（参考）目標指標一覧表"},
    "target_group_number_start": {"type": "integer", "minimum": 1, "maximum": 128},
    "target_group_number_end": {"type": "integer", "minimum": 1, "maximum": 128},
    "series_number_start": {"type": "integer", "minimum": 1, "maximum": 149},
    "series_number_end": {"type": "integer", "minimum": 1, "maximum": 149},
    "items": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/indicator"}},
    "reviewed_at": {"type": "string", "format": "date"},
    "review_status": {"const": "reviewed"},
    "confidence": {"const": "high"}
  },
  "additionalProperties": false,
  "$defs": {
    "value": {
      "type": "object",
      "required": ["role", "period", "value", "status", "aggregation_scope", "value_text_original"],
      "properties": {
        "role": {"enum": ["initial", "current", "intermediate_target", "final_target"]},
        "period": {"type": "string"},
        "value": {"type": ["number", "null"]},
        "status": {"enum": ["numeric", "conditional", "not_set", "not_available"]},
        "operator": {"enum": ["exact", "at_least", "at_most"]},
        "aggregation_scope": {"enum": ["single_period", "multi_year_cumulative", "cumulative_to_date", "snapshot"]},
        "value_text_original": {"type": "string"}
      },
      "additionalProperties": false
    },
    "series": {
      "type": "object",
      "required": ["label", "unit_original", "temporal_scope", "values"],
      "properties": {
        "label": {"type": ["string", "null"]},
        "unit_original": {"type": "string"},
        "temporal_scope": {"enum": ["calendar_year", "fiscal_year", "snapshot", "other"]},
        "values": {"type": "array", "minItems": 4, "maxItems": 4, "items": {"$ref": "#/$defs/value"}}
      },
      "additionalProperties": false
    },
    "indicator": {
      "type": "object",
      "required": [
        "id",
        "target_group_number",
        "series_number",
        "indicator_name_original",
        "scope_type",
        "scope_number",
        "policy_direction_id",
        "policy_id",
        "measure_id",
        "source_pdf_page",
        "source_printed_page",
        "sdg_goal_numbers",
        "series",
        "target_setting_status",
        "comparability_note_original",
        "actual_linkage_status",
        "evaluation_status",
        "review_status",
        "confidence"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^policy-indicator-miyagi-[0-9]+$"},
        "target_group_number": {"type": "integer", "minimum": 1, "maximum": 128},
        "series_number": {"type": "integer", "minimum": 1, "maximum": 149},
        "indicator_name_original": {"type": "string", "minLength": 1},
        "scope_type": {"enum": ["pillar", "measure"]},
        "scope_number": {"type": "integer", "minimum": 1, "maximum": 18},
        "policy_direction_id": {"type": "string"},
        "policy_id": {"type": ["string", "null"]},
        "measure_id": {"type": ["string", "null"]},
        "source_pdf_page": {"type": "integer", "minimum": 56, "maximum": 60},
        "source_printed_page": {"type": "integer", "minimum": 55, "maximum": 59},
        "sdg_goal_numbers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 1, "maximum": 17}},
        "series": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/series"}},
        "target_setting_status": {"enum": ["set", "not_set", "partially_set"]},
        "comparability_note_original": {"type": "string"},
        "actual_linkage_status": {"const": "not_linked"},
        "evaluation_status": {"const": "not_assessed"},
        "review_status": {"const": "reviewed"},
        "confidence": {"const": "high"}
      },
      "additionalProperties": false
    }
  }
}
