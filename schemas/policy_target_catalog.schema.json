{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/policy_target_catalog.schema.json",
  "title": "Jichi Insight Policy Target Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "policy_initiative_id",
    "source_ids",
    "source_document_url",
    "source_page",
    "printed_page",
    "items",
    "reviewed_at",
    "review_status",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^policy-target-catalog-[a-z0-9-]+$"
    },
    "policy_initiative_id": {
      "type": "string",
      "pattern": "^policy-initiative-[a-z0-9-]+$"
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      }
    },
    "source_document_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "source_page": {
      "type": "integer",
      "minimum": 1
    },
    "printed_page": {
      "type": "integer",
      "minimum": 1
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "target_number",
          "submeasure_title_original",
          "indicator_name_original",
          "components",
          "actual_linkage_status",
          "evaluation_status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^policy-target-[a-z0-9-]+$"
          },
          "target_number": {
            "type": "integer",
            "minimum": 1
          },
          "submeasure_title_original": {
            "type": "string",
            "minLength": 1
          },
          "indicator_name_original": {
            "type": "string",
            "minLength": 1
          },
          "components": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "label",
                "baseline_value",
                "baseline_unit",
                "baseline_period",
                "baseline_scope",
                "target_value",
                "target_unit",
                "target_period",
                "target_scope",
                "preferred_direction"
              ],
              "properties": {
                "label": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "baseline_value": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "baseline_unit": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "baseline_period": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "baseline_scope": {
                  "type": "string",
                  "enum": [
                    "snapshot",
                    "annual",
                    "cumulative",
                    "not_available"
                  ]
                },
                "target_value": {
                  "type": "number"
                },
                "target_unit": {
                  "type": "string",
                  "minLength": 1
                },
                "target_period": {
                  "type": "string",
                  "minLength": 1
                },
                "target_scope": {
                  "type": "string",
                  "enum": [
                    "snapshot",
                    "annual",
                    "five_year_cumulative",
                    "cumulative"
                  ]
                },
                "preferred_direction": {
                  "type": "string",
                  "enum": [
                    "increase",
                    "decrease"
                  ]
                }
              }
            }
          },
          "actual_linkage_status": {
            "const": "not_linked"
          },
          "evaluation_status": {
            "const": "not_assessed"
          }
        }
      }
    },
    "reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "review_status": {
      "type": "string",
      "enum": [
        "reviewed",
        "verified"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "not_assessable"
      ]
    }
  }
}
