{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/aichi_policy_indicators.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "municipality_key",
    "prefecture_code",
    "source_id",
    "policy_direction_count",
    "indicator_row_count",
    "unique_indicator_count",
    "series_count",
    "items",
    "reviewed_at",
    "review_status",
    "quality_note"
  ],
  "properties": {
    "id": {"const": "aichi-policy-indicator-catalog-2025"},
    "municipality_key": {"const": "aichi-prefecture"},
    "prefecture_code": {"const": "23"},
    "source_id": {"const": "aichi-report-2025-progress-indicators"},
    "policy_direction_count": {"const": 11},
    "indicator_row_count": {"const": 56},
    "unique_indicator_count": {"const": 54},
    "series_count": {"const": 62},
    "items": {
      "type": "array",
      "minItems": 56,
      "maxItems": 56,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "display_order",
          "policy_direction_code",
          "policy_direction_name_original",
          "indicator_name_original",
          "source_page",
          "is_repost",
          "repost_of_indicator_id",
          "series",
          "comparability_note_original",
          "target_revision",
          "management_evaluation_linkage_status",
          "policy_achievement_assessment_status",
          "review_status",
          "confidence"
        ],
        "properties": {
          "id": {"type": "string", "pattern": "^policy-indicator-aichi-[0-9]{3}$"},
          "display_order": {"type": "integer", "minimum": 1, "maximum": 56},
          "policy_direction_code": {"type": "string", "pattern": "^(00|0[1-9]|10)$"},
          "policy_direction_name_original": {"type": "string", "minLength": 1},
          "indicator_name_original": {"type": "string", "minLength": 1},
          "source_page": {"type": "integer", "minimum": 1, "maximum": 4},
          "is_repost": {"type": "boolean"},
          "repost_of_indicator_id": {"type": ["string", "null"]},
          "series": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "label_original",
                "unit_original",
                "direction",
                "values"
              ],
              "properties": {
                "id": {"type": "string", "pattern": "^policy-indicator-series-aichi-[0-9]{3}-[0-9]{2}$"},
                "label_original": {"type": ["string", "null"]},
                "unit_original": {"type": "string", "minLength": 1},
                "direction": {"enum": ["increase", "decrease", "maintain", "context_only"]},
                "values": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "role",
                      "period",
                      "value",
                      "status",
                      "operator",
                      "aggregation_scope",
                      "value_text_original"
                    ],
                    "properties": {
                      "role": {"enum": ["baseline", "current", "target"]},
                      "period": {"type": "string", "minLength": 1},
                      "value": {"type": ["number", "string", "null"]},
                      "status": {"enum": ["numeric", "qualitative", "missing", "approximate"]},
                      "operator": {"enum": ["exact", "minimum", "maximum", "maintain", "approximate", "not_applicable"]},
                      "aggregation_scope": {"enum": ["single_period", "snapshot", "cumulative", "multi_period_average"]},
                      "value_text_original": {"type": ["string", "null"]}
                    }
                  }
                }
              }
            }
          },
          "comparability_note_original": {"type": "string", "minLength": 1},
          "target_revision": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "required": ["previous_target_text", "current_target_text", "change_note", "source_ids"],
            "properties": {
              "previous_target_text": {"type": "string", "minLength": 1},
              "current_target_text": {"type": "string", "minLength": 1},
              "change_note": {"type": "string", "minLength": 1},
              "source_ids": {"type": "array", "minItems": 2, "uniqueItems": true, "items": {"type": "string"}}
            }
          },
          "management_evaluation_linkage_status": {"const": "not_linked"},
          "policy_achievement_assessment_status": {"const": "not_assessed"},
          "review_status": {"const": "reviewed"},
          "confidence": {"enum": ["high", "medium"]}
        }
      }
    },
    "reviewed_at": {"type": "string", "format": "date"},
    "review_status": {"const": "complete"},
    "quality_note": {"type": "string", "minLength": 30}
  }
}
