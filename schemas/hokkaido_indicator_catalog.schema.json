{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/hokkaido_indicator_catalog.schema.json",
  "title": "Jichi Insight Hokkaido Indicator Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "municipality_key", "policy_field_id", "source_id", "source_document_url", "indicator_number_start", "indicator_number_end", "items", "reviewed_at", "review_status", "confidence"],
  "properties": {
    "id": {"type": "string", "pattern": "^hokkaido-indicator-catalog-[a-z0-9-]+$"},
    "municipality_key": {"const": "hokkaido-prefecture"},
    "policy_field_id": {"type": "string", "pattern": "^policy-field-hokkaido-[a-z0-9-]+$"},
    "source_id": {"type": "string", "pattern": "^policy-source-hokkaido-indicators-[a-z0-9-]+$"},
    "source_document_url": {"type": "string", "format": "uri", "pattern": "^https://"},
    "indicator_number_start": {"type": "integer", "minimum": 1, "maximum": 108},
    "indicator_number_end": {"type": "integer", "minimum": 1, "maximum": 108},
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "indicator_number", "indicator_name_original", "policy_direction_id", "policy_field_ids", "policy_orientation_original", "indicator_explanation_original", "source_page", "series", "target_setting_status", "target_setting_rationale_original", "actual_linkage_status", "evaluation_status", "review_status", "confidence"],
        "properties": {
          "id": {"type": "string", "pattern": "^policy-indicator-hokkaido-[0-9]+$"},
          "indicator_number": {"type": "integer", "minimum": 1, "maximum": 108},
          "indicator_name_original": {"type": "string", "minLength": 1},
          "policy_direction_id": {"type": "string", "pattern": "^policy-direction-hokkaido-[a-z0-9-]+$"},
          "policy_field_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^policy-field-hokkaido-[a-z0-9-]+$"}},
          "policy_orientation_original": {"type": "string", "minLength": 1},
          "indicator_explanation_original": {"type": "string", "minLength": 1},
          "source_page": {"type": "integer", "minimum": 1},
          "series": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "unit_original", "temporal_scope", "values"],
              "properties": {
                "label": {"type": ["string", "null"]},
                "unit_original": {"type": "string", "minLength": 1},
                "temporal_scope": {"type": "string", "enum": ["calendar_year", "fiscal_year", "snapshot", "other"]},
                "values": {
                  "type": "array",
                  "minItems": 3,
                  "maxItems": 3,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["role", "period", "value", "status", "value_text_original"],
                    "properties": {
                      "role": {"type": "string", "enum": ["current", "intermediate_target", "final_target"]},
                      "period": {"type": ["string", "null"]},
                      "value": {"type": ["number", "null"]},
                      "status": {"type": "string", "enum": ["numeric", "not_set", "not_available"]},
                      "operator": {"type": "string", "enum": ["exact", "at_least", "at_most"]},
                      "aggregation_scope": {"type": "string", "enum": ["single_period", "multi_year_cumulative", "snapshot"]},
                      "value_text_original": {"type": "string", "minLength": 1}
                    },
                    "allOf": [
                      {"if": {"properties": {"status": {"const": "numeric"}}}, "then": {"properties": {"value": {"type": "number"}, "period": {"type": "string", "minLength": 1}}}},
                      {"if": {"properties": {"status": {"enum": ["not_set", "not_available"]}}}, "then": {"properties": {"value": {"type": "null"}}}}
                    ]
                  }
                }
              }
            }
          },
          "target_setting_status": {"type": "string", "enum": ["set", "not_set", "partially_set"]},
          "target_setting_rationale_original": {"type": "string", "minLength": 1},
          "comparability_note_original": {"type": ["string", "null"]},
          "actual_linkage_status": {"const": "not_linked"},
          "evaluation_status": {"const": "not_assessed"},
          "review_status": {"const": "reviewed"},
          "confidence": {"const": "high"}
        }
      }
    },
    "reviewed_at": {"type": "string", "format": "date"},
    "review_status": {"const": "reviewed"},
    "confidence": {"const": "high"}
  }
}
