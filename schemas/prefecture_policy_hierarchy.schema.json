{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/prefecture_policy_hierarchy.schema.json",
  "title": "Jichi Insight prefecture policy hierarchy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "prefecture_code",
    "municipality_key",
    "plan_source_ids",
    "plan_title_original",
    "plan_period_start",
    "plan_period_end",
    "plan_period_original",
    "directions",
    "progress_linkage_status",
    "evaluation_status",
    "source_location",
    "reviewed_at",
    "review_status",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^policy-hierarchy-[a-z0-9-]+$"
    },
    "prefecture_code": {
      "type": "string",
      "pattern": "^(0[1-9]|[1-3][0-9]|4[0-7])$"
    },
    "municipality_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "plan_source_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^policy-source-[a-z0-9-]+$"
      }
    },
    "plan_title_original": {
      "type": "string",
      "minLength": 1
    },
    "plan_period_start": {
      "type": "integer",
      "minimum": 1900,
      "maximum": 2200
    },
    "plan_period_end": {
      "type": ["integer", "null"],
      "minimum": 1900,
      "maximum": 2200
    },
    "plan_period_original": {
      "type": "string",
      "minLength": 1
    },
    "directions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "display_order",
          "title_original",
          "fields"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^policy-direction-[a-z0-9-]+$"
          },
          "display_order": {
            "type": "integer",
            "minimum": 1
          },
          "title_original": {
            "type": "string",
            "minLength": 1
          },
          "fields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "display_order", "title_original"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^policy-field-[a-z0-9-]+$"
                },
                "display_order": {
                  "type": "integer",
                  "minimum": 1
                },
                "title_original": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    },
    "progress_linkage_status": {
      "type": "string",
      "enum": ["not_linked", "partial", "linked"]
    },
    "evaluation_status": {
      "type": "string",
      "enum": ["not_assessed", "partially_assessed", "assessed"]
    },
    "source_location": {
      "type": "string",
      "minLength": 1
    },
    "reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "review_status": {
      "type": "string",
      "enum": ["reviewed", "verified"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "not_assessable"]
    }
  }
}