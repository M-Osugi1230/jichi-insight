{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/miyagi_kpi_actuals.schema.json",
  "title": "Jichi Insight Miyagi KPI annual actuals linkage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "municipality_key",
    "source_id",
    "source_document_url",
    "evaluation_fiscal_year",
    "subject_fiscal_year",
    "measure_number",
    "records",
    "reviewed_at",
    "review_status",
    "confidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^miyagi-kpi-actuals-[a-z0-9-]+$"
    },
    "municipality_key": {
      "const": "miyagi-prefecture"
    },
    "source_id": {
      "const": "policy-source-miyagi-results-evaluation-2025"
    },
    "source_document_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "evaluation_fiscal_year": {
      "const": 2025
    },
    "subject_fiscal_year": {
      "const": 2024
    },
    "measure_number": {
      "type": "integer",
      "minimum": 1,
      "maximum": 18
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/record"
      }
    },
    "reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "review_status": {
      "const": "reviewed"
    },
    "confidence": {
      "const": "high"
    }
  },
  "$defs": {
    "periodValue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "period_original",
        "period_year",
        "value",
        "value_text_original",
        "unit_original"
      ],
      "properties": {
        "period_original": {
          "enum": [
            "H30",
            "R1",
            "R2",
            "R3",
            "R4",
            "R5",
            "R6"
          ]
        },
        "period_year": {
          "type": "integer",
          "minimum": 2018,
          "maximum": 2024
        },
        "value": {
          "type": "number"
        },
        "value_text_original": {
          "type": "string",
          "minLength": 1
        },
        "unit_original": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "annualResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reporting_period_original",
        "reporting_year",
        "measurement_period_original",
        "measurement_year",
        "value",
        "value_text_original",
        "unit_original",
        "achievement_rate_text_original",
        "achievement_rate_value",
        "achievement_rate_status",
        "achievement_grade"
      ],
      "properties": {
        "reporting_period_original": {
          "enum": [
            "R3",
            "R4",
            "R5",
            "R6"
          ]
        },
        "reporting_year": {
          "type": "integer",
          "minimum": 2021,
          "maximum": 2024
        },
        "measurement_period_original": {
          "enum": [
            "R1",
            "R2",
            "R3",
            "R4",
            "R5",
            "R6"
          ]
        },
        "measurement_year": {
          "type": "integer",
          "minimum": 2019,
          "maximum": 2024
        },
        "value": {
          "type": "number"
        },
        "value_text_original": {
          "type": "string",
          "minLength": 1
        },
        "unit_original": {
          "type": "string",
          "minLength": 1
        },
        "achievement_rate_text_original": {
          "type": "string",
          "minLength": 1
        },
        "achievement_rate_value": {
          "type": [
            "number",
            "null"
          ]
        },
        "achievement_rate_status": {
          "enum": [
            "numeric",
            "above_100",
            "below_0"
          ]
        },
        "achievement_grade": {
          "enum": [
            "A",
            "B",
            "C",
            "D",
            "not_set"
          ]
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "target_group_id",
        "series_id",
        "linkage_status",
        "match_basis",
        "source_indicator_number",
        "source_indicator_name_original",
        "source_pdf_page",
        "achievement_rate_type_original",
        "evaluation_baseline",
        "evaluation_target",
        "annual_results",
        "comparability_note_original",
        "review_status",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^miyagi-kpi-actual-link-[0-9]+$"
        },
        "target_group_id": {
          "type": "string",
          "pattern": "^policy-target-miyagi-[0-9]+$"
        },
        "series_id": {
          "type": "string",
          "pattern": "^policy-indicator-miyagi-[0-9]+$"
        },
        "linkage_status": {
          "enum": [
            "linked",
            "needs_review"
          ]
        },
        "match_basis": {
          "enum": [
            "exact_name_and_unit",
            "normalized_name_and_unit",
            "definition_changed"
          ]
        },
        "source_indicator_number": {
          "type": "integer",
          "minimum": 1
        },
        "source_indicator_name_original": {
          "type": "string",
          "minLength": 1
        },
        "source_pdf_page": {
          "type": "integer",
          "minimum": 1,
          "maximum": 210
        },
        "achievement_rate_type_original": {
          "type": "string",
          "minLength": 1
        },
        "evaluation_baseline": {
          "$ref": "#/$defs/periodValue"
        },
        "evaluation_target": {
          "$ref": "#/$defs/periodValue"
        },
        "annual_results": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "$ref": "#/$defs/annualResult"
          }
        },
        "comparability_note_original": {
          "type": "string",
          "minLength": 1
        },
        "review_status": {
          "const": "reviewed"
        },
        "confidence": {
          "enum": [
            "high",
            "medium"
          ]
        }
      }
    }
  }
}