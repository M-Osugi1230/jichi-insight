{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/phase9_plan_history.schema.json",
  "title": "Phase 9 plan history boundaries",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "prefecture_count", "tracked_history_count", "records", "updated_at"],
  "properties": {
    "id": {"const": "phase9-plan-history"},
    "prefecture_count": {"const": 38},
    "tracked_history_count": {"const": 38},
    "records": {
      "type": "array",
      "minItems": 38,
      "maxItems": 38,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["prefecture_code", "name", "current_plan_title", "current_plan_period", "target_source_boundary", "source_registry_path", "history_status"],
        "properties": {
          "prefecture_code": {"type": "string", "pattern": "^[0-9]{2}$"},
          "name": {"type": "string", "minLength": 2},
          "current_plan_title": {"type": "string", "minLength": 1},
          "current_plan_period": {"type": "string", "minLength": 1},
          "target_source_boundary": {"type": "string", "minLength": 20},
          "source_registry_path": {"type": "string", "pattern": "^data/catalog/phase9_.*_source_registry\\.json$"},
          "history_status": {"const": "tracked"}
        }
      }
    },
    "updated_at": {"type": "string", "format": "date"}
  }
}
