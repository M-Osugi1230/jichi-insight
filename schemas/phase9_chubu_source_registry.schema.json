{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/phase9_chubu_source_registry.schema.json",
  "title": "Phase 9 Chubu numeric-target source registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "batch_id", "updated_at", "prefecture_codes", "records"],
  "properties": {
    "id": {"const": "phase9-chubu-source-registry"},
    "batch_id": {"const": "chubu"},
    "updated_at": {"type": "string", "format": "date"},
    "prefecture_codes": {
      "type": "array",
      "prefixItems": [
        {"const": "15"}, {"const": "16"}, {"const": "17"},
        {"const": "18"}, {"const": "19"}, {"const": "20"},
        {"const": "21"}, {"const": "22"}, {"const": "24"}
      ],
      "minItems": 9,
      "maxItems": 9
    },
    "records": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {"$ref": "#/$defs/record"}
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "title", "url", "availability", "target_version_scope", "checked_at", "note"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "role": {"enum": ["current_plan", "numeric_target_source", "annual_monitoring", "annual_evaluation", "evaluation_framework"]},
        "title": {"type": "string", "minLength": 1},
        "url": {
          "anyOf": [
            {"type": "string", "format": "uri", "pattern": "^https://"},
            {"type": "null"}
          ]
        },
        "availability": {"enum": ["published", "not_yet_published"]},
        "target_version_scope": {"enum": ["current_plan", "prior_plan"]},
        "checked_at": {"type": "string", "format": "date"},
        "note": {"type": "string", "minLength": 10}
      },
      "allOf": [
        {
          "if": {"properties": {"availability": {"const": "published"}}},
          "then": {"properties": {"url": {"type": "string", "format": "uri"}}}
        },
        {
          "if": {"properties": {"availability": {"const": "not_yet_published"}}},
          "then": {"properties": {"url": {"type": "null"}}}
        }
      ]
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["prefecture_code", "name", "current_plan_title", "current_plan_period", "numeric_target_status", "review_status", "target_source_boundary", "sources"],
      "properties": {
        "prefecture_code": {"enum": ["15", "16", "17", "18", "19", "20", "21", "22", "24"]},
        "name": {"enum": ["新潟県", "富山県", "石川県", "福井県", "山梨県", "長野県", "岐阜県", "静岡県", "三重県"]},
        "current_plan_title": {"type": "string", "minLength": 1},
        "current_plan_period": {"type": "string", "minLength": 1},
        "numeric_target_status": {"const": "indexed"},
        "review_status": {"const": "source_indexed"},
        "target_source_boundary": {"type": "string", "minLength": 20},
        "sources": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {"$ref": "#/$defs/source"}
        }
      }
    }
  }
}
