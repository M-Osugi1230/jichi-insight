{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/osaka_beyond_expo_indicator_review_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "prefecture_code",
    "municipality_key",
    "source_id",
    "source_page_count",
    "reviewed_indicator_section_pages",
    "strategy_target_count",
    "objective_kpi_count",
    "subjective_indicator_count",
    "reviewed_indicator_row_count",
    "reviewed_indicator_series_count",
    "evidence_packet_count",
    "subjective_indicators_with_2024_value",
    "subjective_indicators_pending_first_survey",
    "explicit_numeric_target_count",
    "legacy_vision_linked_series_count",
    "business_list_linked_indicator_count",
    "policy_achievement_assessed_indicator_count",
    "status",
    "updated_at",
    "next_review_scope",
    "quality_note"
  ],
  "properties": {
    "id": {"const": "osaka-beyond-expo-indicator-review-manifest"},
    "prefecture_code": {"const": "27"},
    "municipality_key": {"const": "osaka-prefecture"},
    "source_id": {"const": "osaka-beyond-expo-2025-final"},
    "source_page_count": {"const": 90},
    "reviewed_indicator_section_pages": {"const": [73, 74, 75, 76]},
    "strategy_target_count": {"const": 1},
    "objective_kpi_count": {"const": 27},
    "subjective_indicator_count": {"const": 55},
    "reviewed_indicator_row_count": {"const": 83},
    "reviewed_indicator_series_count": {"const": 91},
    "evidence_packet_count": {"const": 83},
    "subjective_indicators_with_2024_value": {"const": 50},
    "subjective_indicators_pending_first_survey": {"const": 5},
    "explicit_numeric_target_count": {"const": 1},
    "legacy_vision_linked_series_count": {"const": 0},
    "business_list_linked_indicator_count": {"const": 0},
    "policy_achievement_assessed_indicator_count": {"const": 0},
    "status": {"const": "complete"},
    "updated_at": {"type": "string", "format": "date"},
    "next_review_scope": {"type": "string", "minLength": 20},
    "quality_note": {"type": "string", "minLength": 30}
  }
}
