{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/inspection_trip.schema.json",
  "title": "Jichi Insight Inspection Trip",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "assembly_id",
    "trip_type",
    "title",
    "start_date",
    "end_date",
    "purpose",
    "cost_status",
    "report_status",
    "review_status",
    "confidence",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-inspection-[0-9]{4}-[a-z0-9-]+$"
    },
    "assembly_id": {"type": "string", "minLength": 1},
    "trip_type": {"type": "string", "enum": ["domestic", "overseas"]},
    "title": {"type": "string", "minLength": 1},
    "start_date": {"type": "string", "format": "date"},
    "end_date": {"type": "string", "format": "date"},
    "purpose": {"type": "string", "minLength": 1},
    "destinations": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "participants": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "role", "participant_type", "funding_status"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "role": {"type": "string", "minLength": 1},
          "participant_type": {
            "type": "string",
            "enum": ["elected_member", "coordinator", "staff", "other"]
          },
          "funding_status": {
            "type": "string",
            "enum": ["public", "personal", "political_activity_expense", "unknown"]
          }
        }
      }
    },
    "participant_count": {"type": ["integer", "null"], "minimum": 1},
    "total_cost_yen": {"type": ["integer", "null"], "minimum": 0},
    "cost_per_person_yen": {"type": ["integer", "null"], "minimum": 0},
    "cost_status": {
      "type": "string",
      "enum": ["available", "not_published", "not_found", "not_applicable", "unknown"]
    },
    "report_status": {
      "type": "string",
      "enum": ["published", "not_published", "not_found", "not_applicable", "unknown"]
    },
    "policy_follow_up": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "review_status": {
      "type": "string",
      "enum": ["verified", "reviewed", "extracted", "inferred", "missing"]
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low", "not_assessable"]
    },
    "sources": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z0-9-]+$"},
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
