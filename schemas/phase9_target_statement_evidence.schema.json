{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/phase9_target_statement_evidence.schema.json",
  "title": "Phase 9 target statement Evidence Packets",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "prefecture_code", "packet_count", "packets", "updated_at"],
  "properties": {
    "id": {"type": "string", "pattern": "^phase9-[0-9]{2}-target-statement-evidence$"},
    "prefecture_code": {"type": "string", "pattern": "^[0-9]{2}$"},
    "packet_count": {"type": "integer", "minimum": 1, "maximum": 1500},
    "packets": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1500,
      "items": {"$ref": "#/$defs/packet"}
    },
    "updated_at": {"type": "string", "format": "date"}
  },
  "$defs": {
    "sourceLocation": {
      "type": "object",
      "required": ["location_kind"],
      "properties": {
        "location_kind": {"enum": ["pdf_text_line", "pdf_table_row", "workbook_row", "docx_paragraph", "docx_table_row", "html_table_row", "html_text_line"]},
        "page": {"type": "integer", "minimum": 1},
        "sheet": {"type": "string", "minLength": 1},
        "table": {"type": "integer", "minimum": 1},
        "row": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "value_original"],
      "properties": {
        "field": {"enum": ["indicator_name", "target_statement", "numeric_tokens", "period_tokens", "unit", "population_scope"]},
        "value_original": {"type": ["string", "null"]}
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "subject_id", "source_url", "source_document_title", "source_document_sha256", "source_location", "claims", "review_method", "review_status"],
      "properties": {
        "id": {"type": "string", "pattern": "^phase9-[0-9]{2}-target-[0-9]{4}-evidence$"},
        "subject_id": {"type": "string", "pattern": "^phase9-[0-9]{2}-target-[0-9]{4}$"},
        "source_url": {"type": "string", "format": "uri", "pattern": "^https://"},
        "source_document_title": {"type": "string", "minLength": 1},
        "source_document_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "source_location": {"$ref": "#/$defs/sourceLocation"},
        "claims": {"type": "array", "minItems": 6, "maxItems": 6, "items": {"$ref": "#/$defs/claim"}},
        "review_method": {"const": "deterministic_official_source_review_v1"},
        "review_status": {"const": "reviewed"}
      }
    }
  }
}
