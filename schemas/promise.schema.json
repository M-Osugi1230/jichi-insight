{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/promise.schema.json",
  "title": "Jichi Insight Promise",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "municipality_id",
    "executive_term_id",
    "original_text",
    "source_location",
    "statement_type",
    "policy_area",
    "progress_state",
    "assessability",
    "controllability",
    "review_status",
    "confidence",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+-promise-[0-9]{3,}$"
    },
    "municipality_id": {
      "type": "string",
      "pattern": "^jp-local-[0-9]{6}$"
    },
    "executive_term_id": {
      "type": "string",
      "minLength": 1
    },
    "original_text": {
      "type": "string",
      "minLength": 1
    },
    "source_location": {
      "type": "string",
      "minLength": 1
    },
    "statement_type": {
      "type": "string",
      "enum": [
        "specific_commitment",
        "directional_commitment",
        "vision",
        "supporting_context"
      ]
    },
    "plain_summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "policy_area": {
      "type": "string",
      "minLength": 1
    },
    "baseline": {
      "type": [
        "number",
        "string",
        "null"
      ]
    },
    "target": {
      "type": [
        "number",
        "string",
        "null"
      ]
    },
    "deadline": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "funding_statement": {
      "type": [
        "string",
        "null"
      ]
    },
    "controllability": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "shared",
        "not_assessable"
      ]
    },
    "assessability": {
      "type": "string",
      "enum": [
        "assessable",
        "partially_assessable",
        "not_assessable"
      ]
    },
    "progress_state": {
      "type": "string",
      "enum": [
        "achieved",
        "mostly_achieved",
        "partially_achieved",
        "in_progress",
        "not_started",
        "changed",
        "abandoned",
        "not_assessable"
      ]
    },
    "related_project_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "change_explanation": {
      "type": [
        "string",
        "null"
      ]
    },
    "extraction_note": {
      "type": [
        "string",
        "null"
      ]
    },
    "review_status": {
      "type": "string",
      "enum": [
        "verified",
        "reviewed",
        "extracted",
        "inferred",
        "missing"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "not_assessable"
      ]
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "statement_type": {
            "enum": ["vision", "supporting_context"]
          }
        },
        "required": ["statement_type"]
      },
      "then": {
        "properties": {
          "assessability": {"const": "not_assessable"},
          "progress_state": {"const": "not_assessable"}
        }
      }
    },
    {
      "if": {
        "properties": {
          "assessability": {"const": "not_assessable"}
        },
        "required": ["assessability"]
      },
      "then": {
        "properties": {
          "progress_state": {"const": "not_assessable"}
        }
      }
    }
  ]
}
