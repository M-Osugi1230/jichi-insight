{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/policy_review_manifest.schema.json",
  "title": "Jichi Insight policy review manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "updated_at",
    "prefecture_code",
    "municipality_key",
    "plan_source_ids",
    "expected_indicator_count",
    "count_basis",
    "active_work_package",
    "extraction_status",
    "work_packages",
    "quality_requirements",
    "open_questions"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^policy-review-manifest-[a-z0-9-]+$"
    },
    "updated_at": {
      "type": "string",
      "format": "date"
    },
    "prefecture_code": {
      "type": "string",
      "pattern": "^(0[1-9]|[1-3][0-9]|4[0-7])$"
    },
    "municipality_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "plan_source_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^policy-source-[a-z0-9-]+$"
      }
    },
    "expected_indicator_count": {
      "type": "integer",
      "minimum": 1
    },
    "count_basis": {
      "type": "string",
      "minLength": 1
    },
    "active_work_package": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "extraction_status": {
      "type": "string",
      "enum": ["planned", "in_progress", "extracted", "reviewed"]
    },
    "work_packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "deliverable", "completion_gate"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "status": {
            "type": "string",
            "enum": ["queued", "active", "blocked", "completed"]
          },
          "deliverable": {
            "type": "string",
            "minLength": 1
          },
          "completion_gate": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "quality_requirements": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "official_order_preserved",
          "original_text_preserved",
          "units_and_periods_preserved",
          "conditional_targets_not_numericized",
          "missing_values_not_zeroed",
          "repeated_indicators_reference_only",
          "evidence_packet_required",
          "actuals_not_inferred"
        ]
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}