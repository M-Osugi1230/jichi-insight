{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/project.schema.json",
  "title": "Jichi Insight Project",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "municipality_id",
    "fiscal_year",
    "official_title",
    "plain_title",
    "purpose",
    "policy_area",
    "budget_records",
    "kpis",
    "review_status",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^jp-local-[0-9]{6}-project-[0-9]{4}-[a-z0-9-]+$"
    },
    "municipality_id": {
      "type": "string",
      "pattern": "^jp-local-[0-9]{6}$"
    },
    "fiscal_year": {
      "type": "integer",
      "minimum": 1900,
      "maximum": 2200
    },
    "official_title": {
      "type": "string",
      "minLength": 1
    },
    "plain_title": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "target_population": {
      "type": [
        "string",
        "null"
      ]
    },
    "policy_area": {
      "type": "string",
      "enum": [
        "governance",
        "finance",
        "digital",
        "childcare",
        "education",
        "health",
        "welfare",
        "industry",
        "employment",
        "tourism",
        "agriculture",
        "environment",
        "infrastructure",
        "transport",
        "housing",
        "safety",
        "disaster_prevention",
        "culture",
        "sports",
        "other"
      ]
    },
    "related_promise_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "budget_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "amount_yen",
          "fiscal_year"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "initial_budget",
              "revised_budget",
              "execution",
              "settlement"
            ]
          },
          "amount_yen": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "fiscal_year": {
            "type": "integer",
            "minimum": 1900,
            "maximum": 2200
          },
          "note": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "kpis": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "unit",
          "baseline",
          "target",
          "actual",
          "assessment"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "baseline": {
            "type": [
              "number",
              "string",
              "null"
            ]
          },
          "target": {
            "type": [
              "number",
              "string",
              "null"
            ]
          },
          "actual": {
            "type": [
              "number",
              "string",
              "null"
            ]
          },
          "assessment": {
            "type": "string",
            "enum": [
              "achieved",
              "mostly_achieved",
              "partially_achieved",
              "in_progress",
              "not_achieved",
              "not_assessable"
            ]
          }
        }
      }
    },
    "review_status": {
      "type": "string",
      "enum": [
        "verified",
        "reviewed",
        "extracted",
        "inferred",
        "missing"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "not_assessable"
      ]
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^source-[a-z0-9-]+$"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
