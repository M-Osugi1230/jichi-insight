{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://jichi-insight.example/schemas/kpi.schema.json","title":"Jichi Insight KPI","type":"object","additionalProperties":false,"required":["id","project_id","name","definition","unit","direction","assessment","review_status","confidence","sources"],"properties":{"id":{"type":"string","pattern":"^[a-z0-9-]+-kpi-[a-z0-9-]+$"},"project_id":{"type":"string","minLength":1},"name":{"type":"string","minLength":1},"definition":{"type":"string","minLength":1},"unit":{"type":"string","minLength":1},"direction":{"type":"string","enum":["increase","decrease","maintain","range","not_applicable"]},"baseline":{"$ref":"#/$defs/observation"},"target":{"$ref":"#/$defs/observation"},"actuals":{"type":"array","items":{"$ref":"#/$defs/observation"}},"assessment":{"type":"string","enum":["achieved","mostly_achieved","partially_achieved","in_progress","not_achieved","not_assessable"]},"causality_note":{"type":["string","null"]},"review_status":{"type":"string","enum":["verified","reviewed","extracted","inferred","missing"]},"confidence":{"type":"string","enum":["high","medium","low","not_assessable"]},"sources":{"type":"array","items":{"type":"string","pattern":"^[a-z0-9-]+$"},"minItems":1,"uniqueItems":true}},"$defs":{"observation":{"type":["object","null"],"additionalProperties":false,"required":["period","value","status"],"properties":{"period":{"type":"string","minLength":1},"value":{"type":["number","string","null"]},"status":{"type":"string","enum":["available","not_published","not_found","not_applicable","unknown"]},"source_ids":{"type":"array","items":{"type":"string","pattern":"^[a-z0-9-]+$"},"minItems":1,"uniqueItems":true}}}}}
