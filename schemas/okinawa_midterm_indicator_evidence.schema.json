{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/okinawa_midterm_indicator_evidence.schema.json",
  "title": "Okinawa mid-term indicator Evidence Packets",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "prefecture_code", "packet_count", "packets", "updated_at"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^okinawa-midterm-(major-indicator-evidence|outcome-indicator-evidence-part-[1-3])$"
    },
    "prefecture_code": {"const": "47"},
    "packet_count": {"type": "integer", "enum": [36, 113]},
    "packets": {
      "type": "array",
      "minItems": 36,
      "maxItems": 113,
      "items": {"$ref": "#/$defs/packet"}
    },
    "updated_at": {"type": "string", "format": "date"}
  },
  "$defs": {
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["field", "value_original"],
      "properties": {
        "field": {
          "enum": [
            "policy_code",
            "policy_title",
            "indicator_name",
            "baseline",
            "target_r9",
            "national_current",
            "rationale_source",
            "island_indicator",
            "sdgs_priority"
          ]
        },
        "value_original": {"type": ["string", "null"]}
      }
    },
    "packet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "subject_id",
        "source_url",
        "source_document_title",
        "source_pdf_page",
        "source_table_row",
        "claims",
        "source_value_note",
        "review_status"
      ],
      "properties": {
        "id": {"type": "string", "pattern": "^okinawa-midterm-(major|outcome)-[0-9]{3}-evidence$"},
        "subject_id": {"type": "string", "pattern": "^okinawa-midterm-(major|outcome)-[0-9]{3}$"},
        "source_url": {"type": "string", "format": "uri"},
        "source_document_title": {"type": "string", "minLength": 1},
        "source_pdf_page": {"type": "integer", "minimum": 5, "maximum": 71},
        "source_table_row": {"type": "integer", "minimum": 1},
        "claims": {
          "type": "array",
          "minItems": 9,
          "maxItems": 9,
          "items": {"$ref": "#/$defs/claim"}
        },
        "source_value_note": {"type": ["string", "null"]},
        "review_status": {"const": "reviewed"}
      }
    }
  }
}
