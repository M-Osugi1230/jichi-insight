{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jichi-insight.example/schemas/miyagi_policy_hierarchy.schema.json",
  "title": "Jichi Insight Miyagi policy hierarchy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "prefecture_code",
    "municipality_key",
    "plan_source_ids",
    "plan_title_original",
    "plan_period_start",
    "plan_period_end",
    "plan_period_original",
    "implementation_plan_source_id",
    "implementation_period_start",
    "implementation_period_end",
    "directions",
    "recovery_support_areas",
    "kpi_linkage_status",
    "evaluation_linkage_status",
    "source_location",
    "reviewed_at",
    "review_status",
    "confidence"
  ],
  "properties": {
    "id": {"const": "policy-hierarchy-miyagi"},
    "prefecture_code": {"const": "04"},
    "municipality_key": {"const": "miyagi-prefecture"},
    "plan_source_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^policy-source-[a-z0-9-]+$"}
    },
    "plan_title_original": {"const": "新・宮城の将来ビジョン"},
    "plan_period_start": {"const": 2021},
    "plan_period_end": {"const": 2030},
    "plan_period_original": {"type": "string", "minLength": 1},
    "implementation_plan_source_id": {"type": "string", "pattern": "^policy-source-[a-z0-9-]+$"},
    "implementation_period_start": {"const": 2025},
    "implementation_period_end": {"const": 2027},
    "directions": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "display_order", "title_original", "policies"],
        "properties": {
          "id": {"type": "string", "pattern": "^policy-direction-miyagi-[a-z0-9-]+$"},
          "display_order": {"type": "integer", "minimum": 1, "maximum": 4},
          "title_original": {"type": "string", "minLength": 1},
          "policies": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "policy_number", "display_order", "title_original", "measures"],
              "properties": {
                "id": {"type": "string", "pattern": "^policy-miyagi-[0-9]+$"},
                "policy_number": {"type": "integer", "minimum": 1, "maximum": 8},
                "display_order": {"type": "integer", "minimum": 1, "maximum": 2},
                "title_original": {"type": "string", "minLength": 1},
                "measures": {
                  "type": "array",
                  "minItems": 2,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["id", "measure_number", "display_order", "title_original"],
                    "properties": {
                      "id": {"type": "string", "pattern": "^policy-measure-miyagi-[0-9]+$"},
                      "measure_number": {"type": "integer", "minimum": 1, "maximum": 18},
                      "display_order": {"type": "integer", "minimum": 1},
                      "title_original": {"type": "string", "minLength": 1}
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "recovery_support_areas": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "display_order", "title_original"],
        "properties": {
          "id": {"type": "string", "pattern": "^policy-recovery-area-miyagi-[0-9]+$"},
          "display_order": {"type": "integer", "minimum": 1, "maximum": 4},
          "title_original": {"type": "string", "minLength": 1}
        }
      }
    },
    "kpi_linkage_status": {"enum": ["positions_not_indexed", "positions_indexed", "reviewed"]},
    "evaluation_linkage_status": {"enum": ["sources_indexed", "partial", "linked"]},
    "source_location": {"type": "string", "minLength": 1},
    "reviewed_at": {"type": "string", "format": "date"},
    "review_status": {"const": "reviewed"},
    "confidence": {"const": "high"}
  }
}
